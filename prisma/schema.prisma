model AttendanceSettings {
  id                  String   @id @default(uuid())
  minimumWorkingHours Float?   // e.g. 6.0 — null means no restriction
  fullDayHours        Float    @default(8) // hours needed for PRESENT status
  updatedById         String?
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())

  @@map("attendance_settings")
}

model Attendance {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation("UserAttendance", fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime         // Store as date only (start of day UTC)
  checkInTime DateTime?
  checkOutTime DateTime?
  totalHours  Float?           // Calculated on checkout
  status      AttendanceStatus @default(ABSENT)
  note        String?          // Admin override note
  isManual    Boolean          @default(false) // true if admin manually set
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@index([status])
  @@map("attendances")
}
